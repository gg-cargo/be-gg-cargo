{
	"info": {
		"_postman_id": "barang-api-collection",
		"name": "Barang API",
		"description": "Collection API untuk master data Barang (pempek, dokumen, dll)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000"
		},
		{
			"key": "token",
			"value": "your_jwt_token_here"
		}
	],
	"item": [
		{
			"name": "Create Barang",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"nama_barang\": \"Pempek\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/barang",
					"host": ["{{base_url}}"],
					"path": ["barang"]
				},
				"description": "Membuat barang baru. Memerlukan JWT token."
			}
		},
		{
			"name": "Get All Barang",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/barang",
					"host": ["{{base_url}}"],
					"path": ["barang"],
					"query": [
						{
							"key": "search",
							"value": "pempek",
							"description": "Optional - Filter by nama_barang (partial match)"
						}
					]
				},
				"description": "Mengambil daftar semua barang. Query search opsional untuk filter."
			}
		},
		{
			"name": "Get Barang by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/barang/1",
					"host": ["{{base_url}}"],
					"path": ["barang", "1"]
				},
				"description": "Mengambil detail barang berdasarkan ID."
			}
		},
		{
			"name": "Update Barang",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"nama_barang\": \"Pempek Palembang\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/barang/1",
					"host": ["{{base_url}}"],
					"path": ["barang", "1"]
				},
				"description": "Mengupdate barang. Memerlukan JWT token."
			}
		},
		{
			"name": "Delete Barang",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/barang/1",
					"host": ["{{base_url}}"],
					"path": ["barang", "1"]
				},
				"description": "Menghapus barang. Memerlukan JWT token."
			}
		}
	]
}
